@page
@model CoalShortagePortal.WebApp.Pages.GenMUs.EditModel
@{
    ViewData["Title"] = "Edit Daily MUs";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="fas fa-edit text-primary"></i> Edit Daily MUs
                </h2>
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    @* Success Message *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <strong>Success!</strong> @Html.Raw(TempData["SuccessMessage"])
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @* Error Message *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <strong>Error!</strong> @Html.Raw(TempData["ErrorMessage"])
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="row">
        <!-- Edit Form Card -->
        <div class="col-lg-4 col-md-5 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-pencil-alt"></i>
                        @if (Model.SelectedId.HasValue)
                        {
                            <text>Edit Selected Record</text>
                        }
                        else
                        {
                            <text>Select a Record to Edit</text>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.SelectedId.HasValue)
                    {
                        <div class="alert alert-info mb-3">
                            <strong><i class="fas fa-info-circle"></i> Original Record:</strong><br>
                            Station: <strong>@Model.SelectedRecord?.StationName</strong><br>
                            Date: <strong>@Model.SelectedRecord?.DataDate.ToString("yyyy-MM-dd")</strong><br>
                            MUs: <strong>@Model.SelectedRecord?.DailyMUs.ToString("N2")</strong><br>
                            ExBus: <strong>@Model.SelectedRecord?.ExBus.ToString("N2")</strong>
                        </div>

                        <form method="post" asp-page-handler="Save">
                            <input type="hidden" asp-for="SelectedId" />
                            <input type="hidden" asp-for="StationName" />
                            <input type="hidden" asp-for="DataDate" />
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="form-group">
                                <label class="font-weight-bold">
                                    <i class="fas fa-building text-info"></i> Generating Station
                                </label>
                                <input type="text" class="form-control form-control-lg" value="@Model.StationName" readonly style="background-color: #e9ecef; cursor: not-allowed;" />
                                <small class="form-text text-muted">This field cannot be modified</small>
                            </div>

                            <div class="form-group">
                                <label class="font-weight-bold">
                                    <i class="fas fa-calendar-alt text-primary"></i> Date
                                </label>
                                <input type="text" class="form-control form-control-lg" value="@Model.DataDate.ToString("yyyy-MM-dd")" readonly style="background-color: #e9ecef; cursor: not-allowed;" />
                                <small class="form-text text-muted">This field cannot be modified</small>
                            </div>

                            <hr class="my-3" />
                            <h6 class="text-success mb-3"><i class="fas fa-edit"></i> Editable Fields</h6>

                            <div class="form-group">
                                <label asp-for="DailyMUs" class="font-weight-bold">
                                    <i class="fas fa-chart-line text-success"></i> Daily MUs
                                </label>
                                <input asp-for="DailyMUs" class="form-control form-control-lg" type="number" step="0.01" min="0.01" placeholder="Enter MU value" />
                                <span asp-validation-for="DailyMUs" class="text-danger small"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ExBus" class="font-weight-bold">
                                    <i class="fas fa-plug text-success"></i> ExBus
                                </label>
                                <input asp-for="ExBus" class="form-control form-control-lg" type="number" step="0.01" min="0.01" placeholder="Enter ExBus value" />
                                <span asp-validation-for="ExBus" class="text-danger small"></span>
                            </div>

                            <hr class="my-3" />
                            <h6 class="text-muted mb-3"><i class="fas fa-tachometer-alt"></i> Peak & Generation Details</h6>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="PeakMW" class="font-weight-bold">Peak MW</label>
                                        <input asp-for="PeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                        <span asp-validation-for="PeakMW" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="PeakMWTime" class="font-weight-bold">Time</label>
                                        <input asp-for="PeakMWTime" class="form-control" type="time" />
                                        <span asp-validation-for="PeakMWTime" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="OffPeakMW" class="font-weight-bold">Off Peak MW</label>
                                        <input asp-for="OffPeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                        <span asp-validation-for="OffPeakMW" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="OffPeakMWTime" class="font-weight-bold">Time</label>
                                        <input asp-for="OffPeakMWTime" class="form-control" type="time" />
                                        <span asp-validation-for="OffPeakMWTime" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="DayPeakMW" class="font-weight-bold">Day Peak MW</label>
                                        <input asp-for="DayPeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                        <span asp-validation-for="DayPeakMW" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="DayPeakMWTime" class="font-weight-bold">Time</label>
                                        <input asp-for="DayPeakMWTime" class="form-control" type="time" />
                                        <span asp-validation-for="DayPeakMWTime" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="MinGeneration" class="font-weight-bold">Min Generation</label>
                                        <input asp-for="MinGeneration" class="form-control" type="number" min="1" placeholder="MW" />
                                        <span asp-validation-for="MinGeneration" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group">
                                        <label asp-for="MinGenerationTime" class="font-weight-bold">Time</label>
                                        <input asp-for="MinGenerationTime" class="form-control" type="time" />
                                        <span asp-validation-for="MinGenerationTime" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="btn-group-vertical w-100">
                                <button type="submit" class="btn btn-success btn-lg mb-2">
                                    <i class="fas fa-save"></i> Update Record
                                </button>
                            </div>
                        </form>

                        <form method="post" asp-page-handler="Delete" onsubmit="return confirmDelete();" class="mt-2">
                            <input type="hidden" asp-for="SelectedId" />
                            <button type="submit" class="btn btn-danger btn-lg btn-block">
                                <i class="fas fa-trash"></i> Delete This Record
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-hand-pointer fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Select a record from the table to edit</h5>
                            <p class="text-muted">Click the "Edit" button on any row to get started</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Records Table Card -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i> Available Records
                    </h5>
                    <span class="badge badge-light text-dark">@(Model.AvailableRecords?.Count ?? 0) records</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-hover mb-0">
                            <thead class="thead-dark" style="position: sticky; top: 0; z-index: 10;">
                                <tr>
                                    <th style="width: 12%;"><i class="fas fa-calendar"></i> DATE</th>
                                    <th style="width: 15%;"><i class="fas fa-building"></i> STATION</th>
                                    <th class="text-right" style="width: 10%;"><i class="fas fa-bolt"></i> MUs</th>
                                    <th class="text-right" style="width: 10%;"><i class="fas fa-plug"></i> ExBus</th>
                                    <th class="text-center" style="width: 10%;"><i class="fas fa-arrow-up"></i> PEAK</th>
                                    <th class="text-center" style="width: 10%;"><i class="fas fa-arrow-down"></i> OFF</th>
                                    <th class="text-center" style="width: 10%;"><i class="fas fa-sun"></i> DAY</th>
                                    <th class="text-center" style="width: 10%;"><i class="fas fa-chart-line"></i> MIN</th>
                                    <th class="text-center" style="width: 8%;"><i class="fas fa-cog"></i> ACTION</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AvailableRecords != null && Model.AvailableRecords.Any())
                                {
                                    @foreach (var item in Model.AvailableRecords)
                                    {
                                        <tr class="@(item.Id == Model.SelectedId ? "table-warning" : "")">
                                            <td class="align-middle">
                                                <span class="badge badge-info text-white px-2 py-1" style="font-size: 0.75rem;">
                                                    @item.DataDate.ToString("yyyy-MM-dd")
                                                </span>
                                            </td>
                                            <td class="align-middle">
                                                <strong style="color: #2c3e50; font-size: 0.85rem;">@item.StationName</strong>
                                            </td>
                                            <td class="align-middle text-right">
                                                <span class="badge badge-success text-white px-2 py-1" style="font-size: 0.8rem; font-weight: 600;">
                                                    @item.DailyMUs.ToString("N2")
                                                </span>
                                            </td>
                                            <td class="align-middle text-right">
                                                <span class="badge badge-success text-white px-2 py-1" style="font-size: 0.8rem; font-weight: 600;">
                                                    @item.ExBus.ToString("N2")
                                                </span>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div style="font-size: 0.75rem;">
                                                    <strong>@item.PeakMW</strong><br />
                                                    <small class="text-muted">@item.PeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div style="font-size: 0.75rem;">
                                                    <strong>@item.OffPeakMW</strong><br />
                                                    <small class="text-muted">@item.OffPeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div style="font-size: 0.75rem;">
                                                    <strong>@item.DayPeakMW</strong><br />
                                                    <small class="text-muted">@item.DayPeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div style="font-size: 0.75rem;">
                                                    <strong>@item.MinGeneration</strong><br />
                                                    <small class="text-muted">@item.MinGenerationTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <a asp-page="./Edit" asp-route-id="@item.Id"
                                                   class="btn btn-sm @(item.Id == Model.SelectedId ? "btn-warning" : "btn-primary")"
                                                   title="Edit this record">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="9" class="text-center py-5">
                                            <div style="color: #6c757d;">
                                                <i class="fas fa-inbox fa-3x mb-3 d-block" style="opacity: 0.5;"></i>
                                                <h5>No records found</h5>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #FCF7F7;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.15) !important;
        }

    .card-header {
        border-bottom: 3px solid rgba(0,0,0,0.1);
        padding: 1rem 1.5rem;
    }

    .form-control,
    .form-control-lg {
        border-radius: 8px;
        border: 2px solid #dee2e6;
        transition: all 0.3s;
    }

    .form-control-lg {
        font-size: 1rem;
    }

        .form-control:focus,
        .form-control-lg:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.15);
            transform: translateY(-1px);
        }

    .btn-lg {
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.95rem;
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(40, 167, 69, 0.4);
    }

    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(220, 53, 69, 0.4);
    }

    .table {
        font-size: 0.85rem;
        background-color: #ffffff;
    }

        .table thead th {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.5px;
            padding: 0.75rem 0.5rem;
            background-color: #343a40 !important;
            color: #ffffff !important;
            border: none;
        }

        .table tbody td {
            padding: 0.75rem 0.5rem;
            vertical-align: middle;
            background-color: #ffffff;
            color: #212529;
            border-bottom: 1px solid #dee2e6;
        }

        .table tbody tr {
            transition: all 0.2s;
            border-left: 3px solid transparent;
            background-color: #ffffff;
        }

            .table tbody tr:nth-child(even) {
                background-color: #f8f9fa;
            }

            .table tbody tr:hover {
                background-color: #e9ecef !important;
                border-left-color: #007bff;
                transform: translateX(2px);
            }

                .table tbody tr:hover td {
                    background-color: transparent;
                }

    .table-warning {
        background-color: #fff3cd !important;
        border-left-color: #ffc107 !important;
    }

        .table-warning:hover {
            background-color: #ffe69c !important;
        }

    .badge {
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .badge-info {
        background-color: #17a2b8 !important;
        color: #ffffff !important;
    }

    .badge-success {
        background-color: #28a745 !important;
        color: #ffffff !important;
    }

    .shadow-sm {
        box-shadow: 0 0.125rem 0.75rem rgba(0,0,0,0.08) !important;
    }

    .alert {
        border-radius: 8px;
        border: none;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    label {
        color: #495057;
        margin-bottom: 0.5rem;
    }

    .btn-group-vertical {
        display: flex;
        flex-direction: column;
    }

    hr {
        border-top: 2px solid #dee2e6;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function confirmDelete() {
            return confirm('Are you sure you want to delete this record? This action cannot be undone.');
        }
    </script>
}