@page
@model CoalShortagePortal.WebApp.Pages.GenMUs.IndexModel
@{
    ViewData["Title"] = "Daily MUs";
    var isAdmin = User.Identity.Name?.ToLower() == "admin";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="fas fa-bolt text-warning"></i> Daily MUs Management
                </h2>
                @if (isAdmin)
                {
                    <a asp-page="./Edit" class="btn btn-primary">
                        <i class="fas fa-edit"></i> Manage Records
                    </a>
                }
            </div>
        </div>
    </div>

    @* Success Message *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @* Error Message *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="row">
        <!-- Form Card -->
        <div class="col-lg-4 col-md-5 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add New Entry
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="form-group">
                            <label asp-for="DataDate" class="font-weight-bold">
                                <i class="fas fa-calendar-alt text-primary"></i> Date
                            </label>
                            <input asp-for="DataDate" class="form-control form-control-lg" type="date" />
                            <span asp-validation-for="DataDate" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DailyMUs" class="font-weight-bold">
                                <i class="fas fa-chart-line text-success"></i> Daily MUs
                            </label>
                            <input asp-for="DailyMUs" class="form-control form-control-lg" type="number" step="0.01" placeholder="Enter MU value" />
                            <span asp-validation-for="DailyMUs" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg btn-block">
                            <i class="fas fa-save"></i> Save MU Data
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-table"></i> Recent Records
                    </h5>
                    <span class="badge badge-light text-dark">@(Model.DailyMUsDataList?.Count() ?? 0) records</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="thead-dark">
                                <tr>
                                    <th>
                                        <i class="fas fa-calendar"></i> DATE
                                    </th>
                                    <th>
                                        <i class="fas fa-building"></i> STATION
                                    </th>
                                    <th class="text-right">
                                        <i class="fas fa-bolt"></i> DAILY MUS
                                    </th>
                                    <th>
                                        <i class="fas fa-clock"></i> CREATED
                                    </th>
                                    @if (isAdmin)
                                    {
                                        <th class="text-center">
                                            <i class="fas fa-cog"></i> ACTIONS
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DailyMUsDataList != null && Model.DailyMUsDataList.Any())
                                {
                                    @foreach (var item in Model.DailyMUsDataList)
                                    {
                                        <tr>
                                            <td class="align-middle">
                                                <span class="badge badge-info text-white px-3 py-2" style="font-size: 0.9rem;">
                                                    @item.DataDate.ToString("yyyy-MM-dd")
                                                </span>
                                            </td>
                                            <td class="align-middle">
                                                <strong style="color: #2c3e50;">@item.StationName</strong>
                                            </td>
                                            <td class="align-middle text-right">
                                                <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                    @item.DailyMUs.ToString("N2")
                                                </span>
                                            </td>
                                            <td class="align-middle" style="color: #6c757d;">
                                                <small>@item.Created.ToString("yyyy-MM-dd HH:mm")</small>
                                            </td>
                                            @if (isAdmin)
                                            {
                                                <td class="align-middle text-center">
                                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Edit">
                                                        <i class="fas fa-edit">Edit</i>
                                                    </a>
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="@(isAdmin ? "5" : "4")" class="text-center py-5">
                                            <div style="color: #6c757d;">
                                                <i class="fas fa-inbox fa-3x mb-3 d-block" style="opacity: 0.5;"></i>
                                                <h5>No records found</h5>
                                                <p class="mb-0">Start by adding your first MU entry</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.15) !important;
        }

    .card-header {
        border-bottom: 3px solid rgba(0,0,0,0.1);
        padding: 1rem 1.5rem;
    }

    .form-control-lg {
        border-radius: 8px;
        border: 2px solid #dee2e6;
        transition: all 0.3s;
        font-size: 1rem;
    }

        .form-control-lg:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.15);
            transform: translateY(-1px);
        }

    .btn-lg {
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.95rem;
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(40, 167, 69, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0, 123, 255, 0.4);
    }

    .table {
        font-size: 0.95rem;
        background-color: #ffffff;
    }

        .table thead th {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 1rem;
            background-color: #343a40 !important;
            color: #ffffff !important;
            border: none;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            background-color: #ffffff;
            color: #212529;
            border-bottom: 1px solid #dee2e6;
        }

        .table tbody tr {
            transition: all 0.2s;
            border-left: 3px solid transparent;
            background-color: #ffffff;
        }

            .table tbody tr:nth-child(even) {
                background-color: #f8f9fa;
            }

            .table tbody tr:hover {
                background-color: #e9ecef !important;
                border-left-color: #007bff;
                transform: translateX(2px);
            }

                .table tbody tr:hover td {
                    background-color: transparent;
                }

    .badge {
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .badge-info {
        background-color: #17a2b8 !important;
        color: #ffffff !important;
    }

    .badge-success {
        background-color: #28a745 !important;
        color: #ffffff !important;
    }

    .shadow-sm {
        box-shadow: 0 0.125rem 0.75rem rgba(0,0,0,0.08) !important;
    }

    .alert {
        border-radius: 8px;
        border: none;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    label {
        color: #495057;
        margin-bottom: 0.5rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}