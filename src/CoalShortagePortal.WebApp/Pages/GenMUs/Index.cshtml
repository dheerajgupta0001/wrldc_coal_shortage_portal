@page
@model CoalShortagePortal.WebApp.Pages.GenMUs.IndexModel
@{
    ViewData["Title"] = "Daily MUs";
    var isAdmin = User.Identity.Name?.ToLower() == "admin";
    var yesterday = DateTime.Now.AddDays(-1).ToString("yyyy-MM-dd");
    var isScheduleUser = Model.CurrentUserType == "ISGS" || Model.CurrentUserType == "IPP";
    var colCount = 9 + (isAdmin ? 1 : 0) + (isScheduleUser ? 1 : 0);
}

<div class="container-fluid mt-4">
    <div class="row justify-content-md-center">
        <div class="col-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>
                    <i class="fas fa-bolt text-warning"></i> Daily MUs Management
                </h2>
                @if (isAdmin)
                {
                    <a asp-page="./Edit" class="btn btn-primary">
                        <i class="fas fa-edit"></i> Manage Records
                    </a>
                }
            </div>
        </div>
    </div>

    @* Success Message *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <strong>Success! @TempData["SuccessMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @* Error Message *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> <strong>Error! @TempData["ErrorMessage"]</strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <!-- Form Card -->
    <div class="row justify-content-md-center">
        <div class="col-10 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add New Entry
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="DataDate" class="font-weight-bold">
                                        <i class="fas fa-calendar-alt text-primary"></i> Date
                                    </label>
                                    <input asp-for="DataDate"
                                           class="form-control form-control-lg"
                                           type="date"
                                           min="@yesterday" />
                                    <span asp-validation-for="DataDate" class="text-danger small"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> You can only enter data from yesterday onwards
                                    </small>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="DailyMUs" class="font-weight-bold">
                                        <i class="fas fa-chart-line text-success"></i> Gross
                                    </label>
                                    <input asp-for="DailyMUs" class="form-control form-control-lg" type="number" step="0.01" min="0.01" placeholder="Enter Gross MU value" />
                                    <span asp-validation-for="DailyMUs" class="text-danger small"></span>
                                </div>
                            </div>

                            @* Schedule MUs — only visible for ISGS / IPP users *@
                            @if (isScheduleUser)
                            {
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="ScheduleMUs" class="font-weight-bold">
                                            <i class="fas fa-chart-line text-success"></i> Schedule
                                        </label>
                                        <input asp-for="ScheduleMUs" class="form-control form-control-lg" type="number" step="0.01" min="0.01" placeholder="Enter Schedule MU value" />
                                        <span asp-validation-for="ScheduleMUs" class="text-danger small"></span>
                                    </div>
                                </div>
                            }

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="ExBus" class="font-weight-bold">
                                        <i class="fas fa-plug text-info"></i> Ex Bus
                                    </label>
                                    <input asp-for="ExBus" class="form-control form-control-lg" type="number" step="0.01" min="0.01" placeholder="Enter ExBus value" />
                                    <span asp-validation-for="ExBus" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h6 class="text-muted mb-3"><i class="fas fa-tachometer-alt"></i> Peak & Generation Details</h6>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="PeakMW" class="font-weight-bold">Peak MW</label>
                                    <input asp-for="PeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                    <span asp-validation-for="PeakMW" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="PeakMWTime" class="font-weight-bold">
                                        Peak Time
                                        @if (!isAdmin)
                                        {
                                            <span class="badge badge-secondary badge-sm">Fixed</span>
                                        }
                                    </label>
                                    @if (isAdmin)
                                    {
                                        <input asp-for="PeakMWTime" class="form-control" type="time" />
                                    }
                                    else
                                    {
                                        <input asp-for="PeakMWTime" class="form-control" type="time" readonly style="background-color: #e9ecef; cursor: not-allowed;" />
                                        <small class="form-text text-muted">
                                            <i class="fas fa-lock"></i> Fixed at 19:00 (Admin can modify)
                                        </small>
                                    }
                                    <span asp-validation-for="PeakMWTime" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="OffPeakMW" class="font-weight-bold">Off Peak MW</label>
                                    <input asp-for="OffPeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                    <span asp-validation-for="OffPeakMW" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="OffPeakMWTime" class="font-weight-bold">
                                        Off Peak Time
                                        @if (!isAdmin)
                                        {
                                            <span class="badge badge-secondary badge-sm">Fixed</span>
                                        }
                                    </label>
                                    @if (isAdmin)
                                    {
                                        <input asp-for="OffPeakMWTime" class="form-control" type="time" />
                                    }
                                    else
                                    {
                                        <input asp-for="OffPeakMWTime" class="form-control" type="time" readonly style="background-color: #e9ecef; cursor: not-allowed;" />
                                        <small class="form-text text-muted">
                                            <i class="fas fa-lock"></i> Fixed at 03:00 (Admin can modify)
                                        </small>
                                    }
                                    <span asp-validation-for="OffPeakMWTime" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="DayPeakMW" class="font-weight-bold">Day Peak MW</label>
                                    <input asp-for="DayPeakMW" class="form-control" type="number" min="1" placeholder="MW" />
                                    <span asp-validation-for="DayPeakMW" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="DayPeakMWTime" class="font-weight-bold">Day Peak Time</label>
                                    <input asp-for="DayPeakMWTime" class="form-control" type="time" />
                                    <span asp-validation-for="DayPeakMWTime" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="MinGeneration" class="font-weight-bold">Min Generation</label>
                                    <input asp-for="MinGeneration" class="form-control" type="number" min="1" placeholder="MW" />
                                    <span asp-validation-for="MinGeneration" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="MinGenerationTime" class="font-weight-bold">Min Gen Time</label>
                                    <input asp-for="MinGenerationTime" class="form-control" type="time" />
                                    <span asp-validation-for="MinGenerationTime" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 text-center">
                                <button type="submit" class="btn btn-success btn-lg px-5 mt-3">
                                    <i class="fas fa-save"></i> Save All Data
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="row justify-content-md-center">
        <div class="col-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-table"></i> Recent Records
                    </h5>
                    <span class="badge badge-light text-dark">@(Model.DailyMUsDataList?.Count() ?? 0) records</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="thead-dark">
                                <tr>
                                    <th style="width: 8%;">
                                        <i class="fas fa-calendar"></i> DATE
                                    </th>
                                    <th style="width: 10%;">
                                        <i class="fas fa-building"></i> STATION
                                    </th>
                                    <th class="text-right" style="width: 8%;">
                                        <i class="fas fa-bolt"></i> Gross
                                    </th>
                                    @* Schedule column — only for ISGS / IPP or admin*@
                                    @if (isScheduleUser || isAdmin)
                                    {
                                        <th class="text-right" style="width: 8%;">
                                            <i class="fas fa-bolt"></i> Schedule
                                        </th>
                                    }
                                    <th class="text-right" style="width: 8%;">
                                        <i class="fas fa-plug"></i> Ex Bus
                                    </th>
                                    <th class="text-center" style="width: 10%;">
                                        <i class="fas fa-arrow-up"></i> PEAK
                                    </th>
                                    <th class="text-center" style="width: 10%;">
                                        <i class="fas fa-arrow-down"></i> OFF PEAK
                                    </th>
                                    <th class="text-center" style="width: 10%;">
                                        <i class="fas fa-sun"></i> DAY PEAK
                                    </th>
                                    <th class="text-center" style="width: 10%;">
                                        <i class="fas fa-chart-line"></i> MIN GEN
                                    </th>
                                    <th style="width: 10%;">
                                        <i class="fas fa-clock"></i> CREATED
                                    </th>
                                    @if (isAdmin)
                                    {
                                        <th class="text-center" style="width: 8%;">
                                            <i class="fas fa-cog"></i> ACTIONS
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DailyMUsDataList != null && Model.DailyMUsDataList.Any())
                                {
                                    @foreach (var item in Model.DailyMUsDataList)
                                    {
                                        <tr>
                                            <td class="align-middle">
                                                <span class="badge badge-info text-white px-3 py-2" style="font-size: 0.9rem;">
                                                    @item.DataDate.ToString("yyyy-MM-dd")
                                                </span>
                                            </td>
                                            <td class="align-middle">
                                                <strong style="color: #2c3e50;">@item.StationName</strong>
                                            </td>
                                            <td class="align-middle text-right">
                                                <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                    @item.DailyMUs.ToString("N2")
                                                </span>
                                            </td>
                                            @* Schedule cell — only for ISGS / IPP *@
                                            @if (isScheduleUser || isAdmin)
                                            {
                                                <td class="align-middle text-right">
                                                    <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                        @item.ScheduleMUs.ToString("N2")
                                                    </span>
                                                </td>
                                            }
                                            <td class="align-middle text-right">
                                                <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                    @item.ExBus.ToString("N2")
                                                </span>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div>
                                                    <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                        @item.PeakMW
                                                    </span>
                                                    <br />
                                                    <small class="text-muted" style="font-size: 0.75rem;">@item.PeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div>
                                                    <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                        @item.OffPeakMW
                                                    </span>
                                                    <br />
                                                    <small class="text-muted" style="font-size: 0.75rem;">@item.OffPeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div>
                                                    <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                        @item.DayPeakMW
                                                    </span>
                                                    <br />
                                                    <small class="text-muted" style="font-size: 0.75rem;">@item.DayPeakMWTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle text-center">
                                                <div>
                                                    <span class="badge badge-success text-white px-3 py-2" style="font-size: 0.95rem; font-weight: 600;">
                                                        @item.MinGeneration
                                                    </span>
                                                    <br />
                                                    <small class="text-muted" style="font-size: 0.75rem;">@item.MinGenerationTime.ToString(@"hh\:mm")</small>
                                                </div>
                                            </td>
                                            <td class="align-middle" style="color: #6c757d;">
                                                <small>@item.Created.ToString("yyyy-MM-dd HH:mm")</small>
                                            </td>
                                            @if (isAdmin)
                                            {
                                                <td class="align-middle text-center">
                                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Edit">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="@colCount" class="text-center py-5">
                                            <div style="color: #6c757d;">
                                                <i class="fas fa-inbox fa-3x mb-3 d-block" style="opacity: 0.5;"></i>
                                                <h5>No records found</h5>
                                                <p class="mb-0">Start by adding your first MU entry</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #FCF7F7;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.15) !important;
        }

    .card-header {
        border-bottom: 3px solid rgba(0,0,0,0.1);
        padding: 1rem 1.5rem;
    }

    .form-control,
    .form-control-lg {
        border-radius: 8px;
        border: 2px solid #dee2e6;
        transition: all 0.3s;
    }

    .form-control-lg {
        font-size: 1rem;
    }

        .form-control:focus,
        .form-control-lg:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.15);
            transform: translateY(-1px);
        }

    .btn-lg {
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.95rem;
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(40, 167, 69, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0, 123, 255, 0.4);
    }

    .table {
        font-size: 0.95rem;
        background-color: #ffffff;
    }

        .table thead th {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 1rem;
            background-color: #343a40 !important;
            color: #ffffff !important;
            border: none;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            background-color: #ffffff;
            color: #212529;
            border-bottom: 1px solid #dee2e6;
        }

        .table tbody tr {
            transition: all 0.2s;
            border-left: 3px solid transparent;
            background-color: #ffffff;
        }

            .table tbody tr:nth-child(even) {
                background-color: #f8f9fa;
            }

            .table tbody tr:hover {
                background-color: #e9ecef !important;
                border-left-color: #007bff;
                transform: translateX(2px);
            }

                .table tbody tr:hover td {
                    background-color: transparent;
                }

    .badge {
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .badge-info {
        background-color: #17a2b8 !important;
        color: #ffffff !important;
    }

    .badge-success {
        background-color: #28a745 !important;
        color: #ffffff !important;
    }

    .shadow-sm {
        box-shadow: 0 0.125rem 0.75rem rgba(0,0,0,0.08) !important;
    }

    .alert {
        border-radius: 8px;
        border: none;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    label {
        color: #495057;
        margin-bottom: 0.5rem;
    }

    hr {
        border-top: 2px solid #dee2e6;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}