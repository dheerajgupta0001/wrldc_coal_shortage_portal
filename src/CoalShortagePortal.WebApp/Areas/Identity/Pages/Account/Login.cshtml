@page
@model LoginModel
@addTagHelper *, DNTCaptcha.Core
@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center align-items-center">
    <div class="col col-md-4 col-lg-4 col-xl-3">
        <section>
            <form id="account" method="post">
                <h1>@ViewData["Title"]</h1>
                <hr />

                @* Success/Info Messages *@
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show">
                        <i class="fas fa-info-circle"></i> @TempData["InfoMessage"]
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                    </div>
                }

                <div asp-validation-summary="All" class="text-danger"></div>

                @if (!Model.Input.RequiresOtp)
                {
                    @* =========================================== *@
                    @* Step 1: Username/Email, Password & CAPTCHA  *@
                    @* =========================================== *@
                    <input type="hidden" asp-for="Input.RequiresOtp" />

                    <div class="form-group">
                        <label asp-for="Input.Email"></label>
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="off" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password"></label>
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="off" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-control">
                            <dnt-captcha asp-captcha-generator-max="99"
                                         asp-captcha-generator-min="20"
                                         asp-captcha-generator-language="English"
                                         asp-captcha-generator-display-mode="SumOfTwoNumbers"
                                         asp-use-relative-urls="true"
                                         asp-placeholder="Security code as a number"
                                         asp-validation-error-message="Please enter the security code as a number."
                                         asp-font-name="Tahoma"
                                         asp-font-size="60"
                                         asp-fore-color="#333333"
                                         asp-back-color="#ccc"
                                         asp-text-box-class="text-box single-line form-control col-md-4"
                                         asp-text-box-template="<div class='input-group col-md-4'><span class='input-group-addon'><span class='glyphicon glyphicon-lock'></span></span>{0}</div>"
                                         asp-validation-message-class="text-danger"
                                         asp-refresh-button-class="glyphicon glyphicon-refresh btn-sm"
                                         asp-use-noise="false" />
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-paper-plane"></i> Send OTP
                        </button>
                    </div>
                }
                else
                {
                    @* =========================================== *@
                    @* Step 2: OTP Verification                    *@
                    @* =========================================== *@
                    <input type="hidden" name="Input.RequiresOtp" value="true" />
                    <input type="hidden" asp-for="Input.Email" />

                    <div class="alert alert-success">
                        <i class="fas fa-envelope-open-text"></i>
                        OTP sent to your registered email.
                    </div>

                    @if (Model.IsOtpBlocked)
                    {
                        @* ======================================= *@
                        @* BLOCKED STATE                           *@
                        @* ======================================= *@
                        <div class="alert alert-danger mt-3">
                            <i class="fas fa-ban"></i>
                            <strong>OTP limit exceeded.</strong>
                            Please wait for <strong>@Model.OtpBlockRemainingMinutes minute(s)</strong>
                            before trying again.
                        </div>

                        <div class="form-group">
                            <label asp-for="Input.OtpCode">
                                <i class="fas fa-key"></i> Enter OTP
                            </label>
                            <input asp-for="Input.OtpCode"
                                   class="form-control text-center bg-light"
                                   style="font-size: 28px; letter-spacing: 15px; font-weight: bold;"
                                   maxlength="6"
                                   placeholder="------"
                                   autocomplete="off"
                                   disabled />
                            <small class="form-text text-danger mt-2">
                                <i class="fas fa-lock"></i> OTP entry is temporarily disabled.
                            </small>
                        </div>

                        <div class="form-group mt-3">
                            <button type="submit"
                                    class="btn btn-success btn-block"
                                    disabled>
                                <i class="fas fa-ban"></i> Verify & Login (Blocked)
                            </button>
                        </div>

                        <div class="alert alert-warning mt-2 text-center"
                             id="countdown-container">
                            <i class="fas fa-clock"></i>
                            Time remaining:
                            <strong id="countdown-timer">
                                @(Model.OtpBlockRemainingMinutes * 60)s
                            </strong>
                            <br />
                            <small>You will be redirected to the login page automatically.</small>
                        </div>
                    }
                    else
                    {
                        @* ======================================= *@
                        @* NORMAL OTP STATE                        *@
                        @* ======================================= *@
                        <div class="form-group">
                            <label asp-for="Input.OtpCode">
                                <i class="fas fa-key"></i> Enter OTP
                            </label>
                            <input asp-for="Input.OtpCode"
                                   class="form-control text-center"
                                   style="font-size: 28px; letter-spacing: 15px; font-weight: bold;"
                                   maxlength="6"
                                   placeholder="000000"
                                   autocomplete="off"
                                   autofocus />
                            <span asp-validation-for="Input.OtpCode" class="text-danger"></span>
                            <small class="form-text text-muted mt-2">
                                <i class="fas fa-clock"></i> OTP is valid for 5 minutes
                            </small>
                        </div>

                        <div class="form-group mt-3">
                            <button type="submit" class="btn btn-success btn-block">
                                <i class="fas fa-sign-in-alt"></i> Verify & Login
                            </button>
                        </div>
                    }

                    <div class="form-group mt-2">
                        <a asp-page="./Login" class="btn btn-secondary btn-block">
                            <i class="fas fa-arrow-left"></i> Start Over
                        </a>
                    </div>
                }

            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        // ✅ Get correct login URL dynamically — works in both VS and IIS subfolder
        var loginUrl = '@Url.Page("/Account/Login")';

        // ✅ window.onload fires after ALL resources loaded
        // Works consistently in both IIS and VS — no jQuery dependency
        window.onload = function () {

            // Only numbers allowed in OTP input
            var otpInput = document.getElementById('Input_OtpCode');
            if (otpInput) {
                otpInput.addEventListener('input', function () {
                    this.value = this.value.replace(/[^0-9]/g, '');
                });
            }

            // Countdown timer when OTP is blocked
            var countdownEl = document.getElementById('countdown-timer');
            if (countdownEl) {

                // ✅ Read raw text, trim all whitespace
                var rawText = countdownEl.textContent.trim();

                // ✅ Remove 's' suffix and parse to integer
                var seconds = parseInt(rawText.replace('s', '').trim(), 10);

                // ✅ Validate before starting timer
                if (isNaN(seconds) || seconds <= 0) {
                    // window.location.href = '/Identity/Account/Login';
                    window.location.href = loginUrl;
                    return;
                }

                // ✅ Update display immediately so user sees
                // formatted time (e.g. "5m 0s") not raw "300s"
                var updateDisplay = function (sec) {
                    var m = Math.floor(sec / 60);
                    var s = sec % 60;
                    countdownEl.textContent = m > 0
                        ? m + 'm ' + s + 's'
                        : s + 's';
                };

                // Show formatted time immediately on load
                updateDisplay(seconds);

                // Start countdown interval
                var interval = setInterval(function () {
                    seconds--;
                    if (seconds <= 0) {
                        clearInterval(interval);
                        countdownEl.textContent = '0s';
                        // ✅ Redirect to Login page (Step 1) after block expires
                        window.location.href = loginUrl;
                    } else {
                        updateDisplay(seconds);
                    }
                }, 1000);
            }
        };
    </script>

}