@model CoalShortagePortal.WebApp.Models.StageListVM
@{
    ViewData["Title"] = "Manage Generating Station Stages";
}
<div class="container-fluid mt-4">
    <div class="row justify-content-md-center">
        <div class="col-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>@ViewData["Title"]</h2>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <p>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus"></i> Add New Stage
                    </a>
                </p>

            </div>

            @if (Model.Stages == null || !Model.Stages.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No stages found. Create your first stage using the button above.
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Existing Stages</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Station Name</th>
                                        <th>Stage Number</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stage in Model.Stages)
                                    {
                                        <tr>
                                            <td>@stage.StationName</td>
                                            <td>
                                                <span class="badge bg-info">Stage @stage.Stage</span>
                                            </td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@stage.Id" 
                                                   class="btn btn-sm btn-primary" title="Edit">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@stage.Id" 
                                                   class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="fas fa-trash"></i> Delete
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
