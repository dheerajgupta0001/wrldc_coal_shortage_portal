@model CoalShortagePortal.WebApp.Models.StageEditVM
@{
    ViewData["Title"] = "Edit Stage";
}
<div class="container-fluid mt-4">
    <div class="row justify-content-md-center">
        <div class="col-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>@ViewData["Title"]</h2>

                <hr />
            </div>

            <div class="row">
                <div class="col-md-6">
                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="All" class="text-danger"></div>
            
                        <div class="form-group">
                            <label asp-for="StationName" class="control-label"></label>
                            <select asp-for="StationName" class="form-control">
                                <option value="">-- Select Station --</option>
                                @foreach (var station in Model.AvailableStations)
                                {
                                    <option value="@station" selected="@(station == Model.StationName)">@station</option>
                                }
                            </select>
                            <span asp-validation-for="StationName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Stage" class="control-label"></label>
                            <input asp-for="Stage" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Stage" class="text-danger"></span>
                        </div>

                        <div class="form-group mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Stage
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
    
                <div class="col-md-6">
                    <div class="alert alert-warning">
                        <h5><i class="fas fa-exclamation-triangle"></i> Warning</h5>
                        <p>Be careful when editing stage information. Ensure the new station name and stage number combination doesn't already exist.</p>
                    </div>
                </div>
            </div>

            @section Scripts {
                @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
            }
        </div>
    </div>
</div>
